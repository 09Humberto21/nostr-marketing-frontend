# How the browser reaches the Nostr Marketing Platform API (FastAPI backend).
#
# Recommended (no CORS): route through the same-origin Next.js proxy.
#   1. Set the base URL to the proxy mount point:
NEXT_PUBLIC_API_BASE_URL=/api
#   2. Tell the Next.js server where to forward /api/* (server-side, see next.config.mjs):
BACKEND_ORIGIN=http://localhost:8000
#
# Alternative (direct): point straight at the backend origin. This requires the
# backend to send CORS headers for this app's origin.
#   NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
